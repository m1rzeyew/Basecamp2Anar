@model List<AppUser>
@{
    var adminIds = ViewBag.AdminIds as List<string> ?? new List<string>();
}

<main class="main-content">
    <div class="page-header">
        <h1 class="page-title">Admin Users</h1>
    </div>

    <div class="content-card">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px solid var(--border-color);">
                    <th style="padding: 1rem; text-align: left;">Full Name</th>
                    <th style="padding: 1rem; text-align: left;">Username</th>
                    <th style="padding: 1rem; text-align: left;">Email</th>
                    <th style="padding: 1rem; text-align: left;">Role</th>
                    <th style="padding: 1rem; text-align: left;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var isAdmin = adminIds.Contains(user.Id);

                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 1rem;">@user.FullName</td>
                        <td style="padding: 1rem;">@user.UserName</td>
                        <td style="padding: 1rem;">@user.Email</td>
                        <td style="padding: 1rem;">@(isAdmin ? "Admin" : "Member")</td>
                        <td style="padding: 1rem;">
                            @if (isAdmin)
                            {
                                <form asp-controller="Admin" asp-action="UpdateRole" asp-route-id="@user.Id" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="role" value="Member">
                                    <button type="submit" class="btn btn-gray">Demote</button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Admin" asp-action="UpdateRole" asp-route-id="@user.Id" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="role" value="Admin">
                                    <button type="submit" class="btn btn-primary">Promote</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</main>
