@model Project
@using System.Security.Claims
@{
    Layout = null;
    var currentUserId = (string?)ViewBag.CurrentUserId ?? User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canManageProject = ViewBag.CanManageProject is bool canManage && canManage;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Name | Project Details</title>
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>
<body>
    <header class="header">
        <div class="header-logo">
            <a asp-controller="Dashboard" asp-action="Index" style="text-decoration:none;color:var(--blue-primary);font-weight:700;font-size:0.95rem;">
                <i class="ph ph-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </header>

    <form id="antiForgeryForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <main class="main-content">
        <div class="project-detail-header">
            <h1 class="page-title">@Model.Name</h1>
            <p class="project-detail-desc">@Model.Description</p>
        </div>

        @if (TempData["Error"] is string error)
        {
            <div style="margin-bottom:1rem;padding:0.75rem 1rem;border:1px solid #feb2b2;background:#fff5f5;color:var(--red-primary);border-radius:6px;">
                @error
            </div>
        }

        <div class="project-layout">
            <aside class="sidebar-card">
                <ul class="sidebar-menu">
                    @if (canManageProject)
                    {
                        <li class="sidebar-item">
                            <a asp-action="ManageProject" asp-route-id="@Model.Id" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:0.75rem;width:100%;">
                                <i class="ph ph-gear"></i> Manage Project
                            </a>
                        </li>
                    }
                    <li class="sidebar-item active" data-target="threads">
                        <i class="ph ph-chat-centered-text"></i> Threads
                    </li>
                    <li class="sidebar-item" data-target="discussions">
                        <i class="ph ph-chat-circle-dots"></i> Discussions
                    </li>
                    <li class="sidebar-item" data-target="tasks">
                        <i class="ph ph-check-square"></i> Tasks
                    </li>
                    <li class="sidebar-item" data-target="members">
                        <i class="ph ph-users"></i> Members
                    </li>
                    <li class="sidebar-item" data-target="attachments">
                        <i class="ph ph-paperclip"></i> Attachments
                    </li>
                </ul>
            </aside>

            <section class="main-display">
                <div id="threads" class="content-section content-card active">
                    <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;margin-bottom:1.5rem;">
                        <h2 class="section-title" style="margin-bottom:0;"><i class="ph ph-chat-centered-text"></i> Threads</h2>
                    </div>

                    @if (canManageProject)
                    {
                        <form asp-action="CreateThread" method="post" class="input-group">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="projectId" value="@Model.Id" />
                            <input type="text" name="title" class="form-control" placeholder="Start a new project thread..." required />
                            <button type="submit" class="btn btn-primary"><i class="ph ph-plus"></i> New Thread</button>
                        </form>
                    }

                    <div class="thread-list" style="display:flex;flex-direction:column;gap:1.25rem;">
                        @if (Model.Threads.Any())
                        {
                            @foreach (var thread in Model.Threads.OrderByDescending(t => t.UpdatedAt))
                            {
                                <article class="content-card" style="box-shadow:none;">
                                    <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;">
                                        <div>
                                            <h3 style="font-size:1.1rem;margin-bottom:0.25rem;">@thread.Title</h3>
                                            <p class="timestamp">
                                                Created by @(thread.CreatedByUser?.FullName ?? "Deleted user") on @thread.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                            </p>
                                        </div>
                                        @if (canManageProject)
                                        {
                                            <form asp-action="DeleteThread" method="post" onsubmit="return confirm('Delete this thread and its messages?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="threadId" value="@thread.Id" />
                                                <button type="submit" class="btn-icon btn-delete" title="Delete thread"><i class="ph ph-trash"></i></button>
                                            </form>
                                        }
                                    </div>

                                    @if (canManageProject)
                                    {
                                        <form asp-action="EditThread" method="post" class="input-group" style="margin-top:1rem;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="threadId" value="@thread.Id" />
                                            <input type="text" name="title" class="form-control" value="@thread.Title" required />
                                            <button type="submit" class="btn btn-gray">Rename</button>
                                        </form>
                                    }

                                    <div class="message-list" style="margin-top:1rem;gap:1rem;">
                                        @foreach (var message in thread.Messages.OrderBy(m => m.CreatedAt))
                                        {
                                            var canChangeMessage = message.UserId == currentUserId || canManageProject;
                                            <div class="message-item">
                                                <div class="avatar"><i class="ph ph-user"></i></div>
                                                <div class="message-content">
                                                    <div class="message-header">
                                                        <span class="user-name">@message.User.FullName</span>
                                                        <span class="timestamp">@message.CreatedAt.ToString("dd MMM, HH:mm")</span>
                                                    </div>
                                                    <p class="message-text">@message.Content</p>
                                                    @if (canChangeMessage)
                                                    {
                                                        <form asp-action="EditThreadMessage" method="post" class="input-group" style="margin-top:0.75rem;margin-bottom:0;">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="messageId" value="@message.Id" />
                                                            <input type="text" name="content" class="form-control" value="@message.Content" required />
                                                            <button type="submit" class="btn btn-gray">Save</button>
                                                        </form>
                                                    }
                                                </div>
                                                @if (canChangeMessage)
                                                {
                                                    <form asp-action="DeleteThreadMessage" method="post" onsubmit="return confirm('Delete this message?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="messageId" value="@message.Id" />
                                                        <button type="submit" class="btn-icon btn-delete" title="Delete message"><i class="ph ph-trash"></i></button>
                                                    </form>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <form asp-action="AddThreadMessage" method="post" class="input-group" style="margin-top:1rem;margin-bottom:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="projectThreadId" value="@thread.Id" />
                                        <input type="text" name="content" class="form-control" placeholder="Write a message in this thread..." required />
                                        <button type="submit" class="btn btn-primary">Send</button>
                                    </form>
                                </article>
                            }
                        }
                        else
                        {
                            <p class="project-detail-desc">No threads yet.</p>
                        }
                    </div>
                </div>

                <div id="discussions" class="content-section content-card">
                    <h2 class="section-title"><i class="ph ph-chat-circle"></i> Discussions</h2>

                    <div class="input-group" style="display:flex;gap:0.75rem;margin-bottom:1.5rem;">
                        <input type="text" id="discussionInput" class="form-control"
                               placeholder="Type a project discussion message..."
                               onkeypress="if(event.key==='Enter') sendDiscussion(@Model.Id)">
                        <button class="btn btn-primary" onclick="sendDiscussion(@Model.Id)">Send</button>
                    </div>

                    <div class="message-list" id="messageList">
                        @foreach (var d in Model.Discussions.OrderByDescending(d => d.Id))
                        {
                            var canDeleteDiscussion = d.AppUserId == currentUserId || canManageProject;
                            <div class="message-item" id="msg-@d.Id">
                                <div class="avatar"><i class="ph ph-user"></i></div>
                                <div class="message-content" style="flex:1;">
                                    <div class="message-header">
                                        <span class="user-name">@d.AppUser.FullName</span>
                                        <span class="timestamp">@d.CreatedAt.ToString("dd MMM, HH:mm")</span>
                                    </div>
                                    <p class="message-text">@d.Content</p>
                                </div>
                                @if (canDeleteDiscussion)
                                {
                                    <button onclick="deleteDiscussion(@d.Id)" class="btn-icon btn-delete" title="Delete discussion">
                                        <i class="ph ph-trash"></i>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div id="tasks" class="content-section content-card">
                    <h2 class="section-title"><i class="ph ph-check-square"></i> Tasks</h2>

                    <div class="add-task-container input-group">
                        <input type="text" id="taskInput" placeholder="Add a new task..." class="form-control">
                        <button class="btn btn-primary" onclick="addNewTask(@Model.Id)">Add Task</button>
                    </div>

                    <div class="task-list" id="taskList">
                        @foreach (var task in Model.Tasks.OrderByDescending(t => t.Id))
                        {
                            <div class="task-item @(task.IsCompleted ? "completed" : "")" id="task-@task.Id">
                                <button type="button" class="custom-checkbox" onclick="toggleTask(event, @task.Id)">
                                    @if (task.IsCompleted)
                                    {
                                        <i class="ph ph-check-bold"></i>
                                    }
                                </button>
                                <span class="task-text" onclick="toggleTask(event, @task.Id)">@task.Title</span>
                                <div class="btn-delete-task" onclick="deleteTask(@task.Id)">
                                    <i class="ph ph-trash"></i>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div id="members" class="content-section content-card">
                    <h2 class="section-title"><i class="ph ph-users-three"></i> Project Members</h2>
                    <div class="member-list">
                        @foreach (var member in Model.Members.OrderBy(m => m.Role == "Owner" ? 0 : m.Role == "Admin" ? 1 : 2).ThenBy(m => m.AppUser.FullName))
                        {
                            <div class="member-item">
                                <div class="member-info">
                                    <div class="avatar"><i class="ph ph-user"></i></div>
                                    <span class="user-name">@member.AppUser.FullName</span>
                                </div>
                                <span class="badge-pill badge-owner">@member.Role</span>
                            </div>
                        }
                    </div>
                </div>

                <div id="attachments" class="content-section content-card">
                    <h2 class="section-title"><i class="ph ph-paperclip"></i> Attachments</h2>

                    <div class="file-upload-area" onclick="document.getElementById('fileInput').click()" style="cursor:pointer;">
                        <i class="ph ph-cloud-arrow-up" style="font-size:2.5rem;color:var(--blue-primary);margin-bottom:1rem;display:block;"></i>
                        <p style="font-weight:600;margin-bottom:0.5rem;">Click to choose file</p>
                        <p style="font-size:0.85rem;color:var(--text-secondary);">Allowed formats: PNG, JPG/JPEG, PDF, TXT</p>
                        <input type="file" id="fileInput" style="display:none;" accept=".png,.jpg,.jpeg,.pdf,.txt"
                               onchange="uploadAttachment(@Model.Id, this)">
                    </div>

                    <div id="uploadStatus" style="display:none;margin-top:1rem;color:var(--blue-primary);font-size:0.9rem;">
                        <i class="ph ph-spinner"></i> Uploading...
                    </div>

                    <div class="attachment-list" id="attachmentList" style="margin-top:1.5rem;">
                        @foreach (var att in Model.Attachments.OrderByDescending(a => a.Id))
                        {
                            var canDeleteAttachment = canManageProject || att.UploadedByUserId == currentUserId;
                            var normalizedFileType = att.FileType.TrimStart('.').ToLowerInvariant();
                            var icon = normalizedFileType switch
                            {
                                "pdf" => "ph-file-pdf",
                                "png" or "jpg" or "jpeg" => "ph-image",
                                "txt" => "ph-file-text",
                                _ => "ph-file"
                            };

                            <div class="attachment-item" id="att-@att.Id"
                                 style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:0.75rem 1rem;border:1px solid var(--border-color);border-radius:8px;margin-bottom:0.5rem;">
                                <div style="display:flex;align-items:center;gap:0.75rem;min-width:0;">
                                    <i class="ph @icon" style="font-size:1.5rem;color:var(--blue-primary);"></i>
                                    <div style="min-width:0;">
                                        <a href="@att.FilePath" download="@att.FileName" style="text-decoration:none;color:inherit;font-weight:500;">
                                            @att.FileName
                                        </a>
                                        <div class="timestamp">
                                            @normalizedFileType.ToUpperInvariant() by @(att.UploadedByUser?.FullName ?? "Unknown") on @att.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                        </div>
                                    </div>
                                </div>
                                @if (canDeleteAttachment)
                                {
                                    <button onclick="deleteAttachment(@att.Id)" class="btn-icon btn-delete" title="Delete attachment">
                                        <i class="ph ph-trash"></i>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script>
        function getRequestVerificationToken() {
            return document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;
        }

        function formDataWithToken() {
            const formData = new FormData();
            formData.append('__RequestVerificationToken', getRequestVerificationToken());
            return formData;
        }

        function escapeHtml(value) {
            return value.replace(/[&<>"']/g, function (char) {
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[char];
            });
        }

        function addNewTask(projectId) {
            const input = document.getElementById('taskInput');
            const title = input.value.trim();
            if (!title) return;

            const formData = formDataWithToken();
            formData.append('projectId', projectId);
            formData.append('title', title);

            fetch('/Project/AddTask', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) return alert(data.message || 'Could not add task.');
                    const html = `
                        <div class="task-item" id="task-${data.id}">
                            <button type="button" class="custom-checkbox" onclick="toggleTask(event, ${data.id})"></button>
                            <span class="task-text" onclick="toggleTask(event, ${data.id})">${escapeHtml(data.title)}</span>
                            <div class="btn-delete-task" title="Delete Task" onclick="deleteTask(${data.id})">
                                <i class="ph ph-trash"></i>
                            </div>
                        </div>`;
                    document.getElementById('taskList').insertAdjacentHTML('afterbegin', html);
                    input.value = '';
                });
        }

        function toggleTask(event, taskId) {
            if (event) {
                event.preventDefault();
                event.stopPropagation();
            }

            const formData = formDataWithToken();
            formData.append('taskId', taskId);

            fetch('/Project/ToggleTask', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) return alert(data.message || 'Could not update task.');
                    const taskElement = document.getElementById(`task-${taskId}`);
                    const checkbox = taskElement.querySelector('.custom-checkbox');
                    taskElement.classList.toggle('completed');
                    checkbox.innerHTML = data.isCompleted ? '<i class="ph ph-check-bold"></i>' : '';
                });
        }

        function deleteTask(taskId) {
            if (!confirm('Delete this task?')) return;

            const formData = formDataWithToken();
            formData.append('taskId', taskId);

            fetch('/Project/DeleteTask', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    if (data.success) document.getElementById(`task-${taskId}`).remove();
                });
        }

        document.getElementById('taskInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') addNewTask(@Model.Id);
        });

        function uploadAttachment(projectId, input) {
            const file = input.files[0];
            if (!file) return;

            const status = document.getElementById('uploadStatus');
            status.style.display = 'block';

            const formData = formDataWithToken();
            formData.append('projectId', projectId);
            formData.append('file', file);

            fetch('/Project/UploadAttachment', { method: 'POST', body: formData })
                .then(async res => {
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.message || 'Upload failed.');
                    return data;
                })
                .then(data => {
                    status.style.display = 'none';
                    const icons = { pdf: 'ph-file-pdf', png: 'ph-image', jpg: 'ph-image', jpeg: 'ph-image', txt: 'ph-file-text' };
                    const icon = icons[data.fileType] || 'ph-file';
                    const html = `
                        <div class="attachment-item" id="att-${data.id}"
                             style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:0.75rem 1rem;border:1px solid var(--border-color);border-radius:8px;margin-bottom:0.5rem;">
                            <div style="display:flex;align-items:center;gap:0.75rem;min-width:0;">
                                <i class="ph ${icon}" style="font-size:1.5rem;color:var(--blue-primary);"></i>
                                <div style="min-width:0;">
                                    <a href="${data.filePath}" download="${escapeHtml(data.fileName)}" style="text-decoration:none;color:inherit;font-weight:500;">
                                        ${escapeHtml(data.fileName)}
                                    </a>
                                    <div class="timestamp">${escapeHtml(data.fileType.toUpperCase())} by ${escapeHtml(data.uploader)} on ${escapeHtml(data.createdAt)}</div>
                                </div>
                            </div>
                            <button onclick="deleteAttachment(${data.id})" class="btn-icon btn-delete" title="Delete attachment">
                                <i class="ph ph-trash"></i>
                            </button>
                        </div>`;
                    document.getElementById('attachmentList').insertAdjacentHTML('afterbegin', html);
                    input.value = '';
                })
                .catch(err => {
                    status.style.display = 'none';
                    alert(err.message);
                });
        }

        function deleteAttachment(attachmentId) {
            if (!confirm('Delete this attachment?')) return;

            const formData = formDataWithToken();
            formData.append('attachmentId', attachmentId);

            fetch('/Project/DeleteAttachment', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    if (data.success) document.getElementById(`att-${attachmentId}`).remove();
                });
        }

        function sendDiscussion(projectId) {
            const input = document.getElementById('discussionInput');
            const content = input.value.trim();
            if (!content) return;

            const formData = formDataWithToken();
            formData.append('projectId', projectId);
            formData.append('content', content);

            fetch('/Project/AddDiscussion', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    if (!data.success) return alert(data.message || 'Could not send discussion message.');
                    const html = `
                        <div class="message-item" id="msg-${data.id}">
                            <div class="avatar"><i class="ph ph-user"></i></div>
                            <div class="message-content" style="flex:1;">
                                <div class="message-header">
                                    <span class="user-name">${escapeHtml(data.fullName)}</span>
                                    <span class="timestamp">${escapeHtml(data.createdAt)}</span>
                                </div>
                                <p class="message-text">${escapeHtml(data.content)}</p>
                            </div>
                            <button onclick="deleteDiscussion(${data.id})" class="btn-icon btn-delete" title="Delete discussion">
                                <i class="ph ph-trash"></i>
                            </button>
                        </div>`;
                    document.getElementById('messageList').insertAdjacentHTML('afterbegin', html);
                    input.value = '';
                });
        }

        function deleteDiscussion(discussionId) {
            if (!confirm('Delete this discussion message?')) return;

            const formData = formDataWithToken();
            formData.append('discussionId', discussionId);

            fetch('/Project/DeleteDiscussion', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    if (data.success) document.getElementById(`msg-${discussionId}`).remove();
                });
        }
    </script>
    <script src="~/assets/js/script.js"></script>
</body>
</html>
