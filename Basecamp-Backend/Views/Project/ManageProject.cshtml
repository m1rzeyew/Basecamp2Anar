@model Project
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Settings | Dashboard</title>
  
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>
<body>

    <!-- Header -->
    <header class="header">
        <div class="header-logo">
            <a asp-controller="Dashboard" asp-action="index" style="text-decoration: none; color: var(--blue-primary); font-weight: 700; font-size: 0.95rem;">
                <i class="ph ph-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </header>

    <main class="main-content">
    
        <!-- Top Section -->
        <div class="project-detail-header">
            <h1 class="page-title">Settings</h1>
        </div>

        <div class="project-layout">
      
            <!-- Sidebar (Left) -->
            <aside class="sidebar-card">
                <ul class="sidebar-menu">
                    <li class="sidebar-item active">
                        <a style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.75rem; width: 100%;">
                            <i class="ph ph-gear"></i> Manage Project
                        </a>
                    </li>
                    @* <li class="sidebar-item">
                        <a href="project-details.html" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.75rem; width: 100%;">
                            <i class="ph ph-chat-circle-dots"></i> Discussions
                        </a>
                    </li>
                    <li class="sidebar-item">
                        <a href="project-details.html" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.75rem; width: 100%;">
                            <i class="ph ph-check-square"></i> Tasks
                        </a>
                    </li>
                    <li class="sidebar-item">
                        <a href="project-details.html" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.75rem; width: 100%;">
                            <i class="ph ph-users"></i> Members
                        </a>
                    </li>
                    <li class="sidebar-item">
                        <a href="project-details.html" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 0.75rem; width: 100%;">
                            <i class="ph ph-paperclip"></i> Attachments
                        </a>
                    </li> *@
                </ul>
            </aside>

            <!-- Main Content Area -->
            <div class="settings-layout">
        
                <!-- Main Form (Middle) -->

                

                
                <section class="content-card">
          
                    <div class="settings-section">
                        <label class="settings-label">Project Name</label>
                        <form asp-action="UpdateSettings" method="post" class="input-group">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="text" name="Name" class="form-control" value="@Model.Name">
                            <input type="hidden" name="Description" value="@Model.Description" />
                            <button type="submit" class="btn btn-primary">Update</button>
                        </form>
                    </div>

                    <div class="settings-section">
                        <label class="settings-label">Description</label>
                        <form asp-action="UpdateSettings" method="post" style="display: flex; flex-direction: column; gap: 1rem;">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="Name" value="@Model.Name" />
                            <textarea name="Description" class="form-control" rows="4" style="resize: vertical;">@Model.Description</textarea>
                            <div style="text-align: right;">
                                <button type="submit" class="btn btn-primary">Update</button>
                            </div>
                        </form>
                    </div>

                    <div class="settings-section">
                        <label class="settings-label">Add Member</label>
                        <form asp-action="AddMember" method="post" style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
                            <input type="hidden" name="projectId" value="@Model.Id" />
        
                            <input type="email" name="email" class="form-control" style="flex: 1; min-width: 200px;" placeholder="Enter user email" required>
    
                            <div class="toggle-group">
                                <span style="font-size: 0.9rem; font-weight: 600;">Admin</span>
                                <label class="switch">
                                    <input type="checkbox" name="isAdmin" value="true">
                                    <span class="slider"></span>
                                </label>
                            </div>

                            <button type="submit" class="btn btn-green">
                                <i class="ph ph-user-plus"></i> Add Member
                            </button>
                        </form>
                    </div>

                    <!-- Current Members -->
                    <div class="settings-section">
                        <label class="settings-label">Current Members</label>
                        <div class="members-list">
                            @foreach (var member in Model.Members) // Modelinə uyğun siyahı
                            {
                                <div class="member-item" id="member-row-@member.AppUserId">
                                    <div class="member-info">
                                        <div class="avatar"><i class="ph ph-user"></i></div>
                                        <div>
                                            <span class="user-name">@member.AppUser.FullName</span>
                                            <span class="user-email" style="display:block; font-size:12px; color:gray;">@member.AppUser.Email</span>
                                        </div>
                                    </div>
            
                                    <div class="member-actions" style="display: flex; gap: 10px; align-items: center;">
                                        <select class="form-control-sm" onchange="changeRole('@Model.Id', '@member.AppUserId', this.value)">
                                            <option value="Member" selected="@(member.Role == "Member")">Member</option>
                                            <option value="Admin" selected="@(member.Role == "Admin")">Admin</option>
                                        </select>

                                        <button class="btn-icon text-danger" onclick="removeMemberFromProject('@Model.Id', '@member.AppUserId')">
                                            <i class="ph ph-user-minus"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </section>

                <!-- #endregion -->

                <section class="content-section content-card">
                    <h2 class="section-title"><i class="ph ph-gear"></i> General Settings</h2>
                    <form asp-action="UpdateSettings" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="form-group">
                            <label class="form-label">Project Name</label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required>
                        </div>
                        <div class="form-group" style="margin-top: 1rem;">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                        </div>
                        <button type="submit" class="btn btn-primary" style="margin-top: 1.5rem;">Save Changes</button>
                    </form>
                </section>

                <section class="content-section content-card" style="margin-top: 2rem;">
                    <h2 class="section-title"><i class="ph ph-user-plus"></i> Add New Member</h2>
                    <form asp-action="AddMember" method="post" style="display: flex; gap: 1rem; align-items: flex-end;">
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <div style="flex: 2;">
                            <label class="form-label">User Email</label>
                            <input type="email" name="email" class="form-control" placeholder="example@mail.com" required>
                        </div>
                        <div style="flex: 1;">
                            <label class="form-label">Role</label>
                            <select name="role" class="form-control">
                                <option value="Member">Member</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Add</button>
                    </form>
                </section>

                <section class="content-section content-card" style="margin-top: 2rem;">
                    <h2 class="section-title"><i class="ph ph-users"></i> Project Members</h2>
                    <div class="members-list">
                        @if (Model.Members is not null)
                        {
                            @foreach (var member in Model.Members)
                            {
                                <div class="member-item" id="member-row-@member.AppUserId"
                                     style="display: flex; justify-content: space-between; padding: 1rem; border-bottom: 1px solid var(--border-color);">
                                    <div class="member-info">
                                        <strong>@member.AppUser.FullName</strong>
                                        <span style="font-size: 0.8rem; color: var(--text-secondary);">(@member.AppUser.Email)</span>
                                        <span class="badge" style="margin-left: 10px; background: #eee; padding: 2px 8px; border-radius: 4px;">
                                            @member.Role
                                        </span>
                                    </div>
                
                                    @if (member.Role != "Owner") // Sahibi silmək olmaz
                                    {
                                        <div class="member-actions">
                                            <button onclick="removeMemberFromProject(@Model.Id, '@member.AppUserId')" class="btn-icon btn-delete">
                                                <i class="ph ph-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </section>

                  

                <!-- Right Side Panel -->
                <aside class="sidebar-right">
                    <div class="side-panel">
                        <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline">
                            <i class="ph ph-eye"></i> Preview Project
                        </a>
        
                        <button class="btn btn-outline-danger" onclick="directDeleteProject(@Model.Id)">
                            <i class="ph ph-trash"></i> Delete Project
                        </button>
                    </div>
                </aside>

            </div>
        </div>
    </main>

    <script>
        function directDeleteProject(id) {
        if (confirm("Bu layihəni birdəfəlik silmək istədiyinizə əminsiniz?")) {
        fetch(`/Project/HardDelete?id=${id}`, {
        method: 'POST'
        }).then(res => {
        if(res.ok) {
        // Proyekt silindiyi üçün ana səhifəyə (Dashboard) qayıdırıq
        window.location.href = '/Dashboard/Index';
        } else {
        alert("Silinmə zamanı xəta baş verdi!");
        }
        }).catch(err => {
        console.error("Xəta:", err);
        alert("Bağlantı xətası!");
        });
        }
        }
        function changeRole(projectId, userId, newRole) {
        // Backend-ə rol dəyişikliyini göndəririk
        fetch(`/Project/UpdateMemberRole`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `projectId=${projectId}&userId=${userId}&role=${newRole}`
        }).then(res => {
        if (!res.ok) alert("Could not update role.");
        });
        }

        function removeMemberFromProject(projectId, userId) {
        if (confirm("Are you sure you want to remove this member?")) {
        fetch(`/Project/RemoveMember`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `projectId=${projectId}&userId=${userId}`
        }).then(res => {
        if (res.ok) {
        // Siyahıdan vizual olaraq silirik
        document.getElementById(`member-row-${userId}`).remove();
        } else {
        alert("Error removing member.");
        }
        });
        }
        }
    </script>

    <script src="~/assets/js/script.js"></script>
</body>
</html>

