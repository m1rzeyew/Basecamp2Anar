@model Project
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Name | Project Settings</title>
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>
<body>
    <header class="header">
        <div class="header-logo">
            <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.Id" style="text-decoration:none;color:var(--blue-primary);font-weight:700;font-size:0.95rem;">
                <i class="ph ph-arrow-left"></i> Back to Project
            </a>
        </div>
    </header>

    <form id="antiForgeryForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <main class="main-content">
        <div class="project-detail-header">
            <h1 class="page-title">Settings</h1>
            <p class="project-detail-desc">@Model.Name</p>
        </div>

        @if (TempData["Error"] is string error)
        {
            <div style="margin-bottom:1rem;padding:0.75rem 1rem;border:1px solid #feb2b2;background:#fff5f5;color:var(--red-primary);border-radius:6px;">
                @error
            </div>
        }
        @if (TempData["Success"] is string success)
        {
            <div style="margin-bottom:1rem;padding:0.75rem 1rem;border:1px solid #b7e4c7;background:#f0fff4;color:#276749;border-radius:6px;">
                @success
            </div>
        }

        <div class="settings-layout" style="grid-template-columns:1fr 280px;">
            <section class="content-card">
                <div class="settings-section">
                    <h2 class="section-title"><i class="ph ph-gear"></i> General Settings</h2>
                    <form asp-action="UpdateSettings" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="form-group">
                            <label class="form-label">Project Name</label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </form>
                </div>

                <div class="settings-section">
                    <h2 class="section-title"><i class="ph ph-user-plus"></i> Add Member</h2>
                    <form asp-action="AddMember" method="post" style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <div style="flex:2;min-width:220px;">
                            <label class="form-label">User Email</label>
                            <input type="email" name="email" class="form-control" placeholder="example@mail.com" required>
                        </div>
                        <div style="flex:1;min-width:160px;">
                            <label class="form-label">Project Role</label>
                            <select name="role" class="form-control">
                                <option value="Member">Member</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">Add</button>
                    </form>
                </div>

                <div class="settings-section">
                    <h2 class="section-title"><i class="ph ph-users"></i> Project Members</h2>
                    <div class="members-list">
                        @foreach (var member in Model.Members.OrderBy(m => m.Role == "Owner" ? 0 : m.Role == "Admin" ? 1 : 2).ThenBy(m => m.AppUser.FullName))
                        {
                            <div class="member-item" id="member-row-@member.AppUserId" style="display:flex;justify-content:space-between;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--border-color);">
                                <div class="member-info">
                                    <div class="avatar"><i class="ph ph-user"></i></div>
                                    <div>
                                        <strong>@member.AppUser.FullName</strong>
                                        <span style="display:block;font-size:0.8rem;color:var(--text-secondary);">@member.AppUser.Email</span>
                                    </div>
                                </div>

                                <div class="member-actions" style="display:flex;gap:0.5rem;align-items:center;">
                                    @if (member.Role == "Owner")
                                    {
                                        <span class="badge-pill badge-owner">Owner</span>
                                    }
                                    else
                                    {
                                        <select class="form-control" style="width:140px;" onchange="changeRole('@Model.Id', '@member.AppUserId', this.value)">
                                            <option value="Member" selected="@(member.Role == "Member")">Member</option>
                                            <option value="Admin" selected="@(member.Role == "Admin")">Admin</option>
                                        </select>
                                        <button class="btn-icon btn-delete" onclick="removeMemberFromProject('@Model.Id', '@member.AppUserId')" title="Remove member">
                                            <i class="ph ph-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </section>

            <aside class="sidebar-right">
                <div class="side-panel">
                    <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline">
                        <i class="ph ph-eye"></i> Preview Project
                    </a>
                    <button class="btn btn-danger" onclick="directDeleteProject(@Model.Id)">
                        <i class="ph ph-trash"></i> Delete Project
                    </button>
                </div>
            </aside>
        </div>
    </main>

    <script>
        function getRequestVerificationToken() {
            return document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;
        }

        function tokenFormData() {
            const formData = new FormData();
            formData.append('__RequestVerificationToken', getRequestVerificationToken());
            return formData;
        }

        function directDeleteProject(id) {
            if (!confirm('Delete this project permanently?')) return;

            const formData = tokenFormData();
            formData.append('id', id);

            fetch('/Project/HardDelete', {
                method: 'POST',
                body: formData
            }).then(res => {
                if (res.ok) {
                    window.location.href = '/Dashboard/Index';
                } else {
                    alert('Could not delete the project.');
                }
            });
        }

        function changeRole(projectId, userId, newRole) {
            const formData = tokenFormData();
            formData.append('projectId', projectId);
            formData.append('userId', userId);
            formData.append('role', newRole);

            fetch('/Project/UpdateMemberRole', {
                method: 'POST',
                body: formData
            }).then(res => {
                if (!res.ok) alert('Could not update role.');
            });
        }

        function removeMemberFromProject(projectId, userId) {
            if (!confirm('Remove this member from the project?')) return;

            const formData = tokenFormData();
            formData.append('projectId', projectId);
            formData.append('userId', userId);

            fetch('/Project/RemoveMember', {
                method: 'POST',
                body: formData
            }).then(res => {
                if (res.ok) {
                    document.getElementById(`member-row-${userId}`).remove();
                } else {
                    alert('Could not remove member.');
                }
            });
        }
    </script>
    <script src="~/assets/js/script.js"></script>
</body>
</html>
