@model AppUser
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile | Dashboard</title>

    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>

<body>

    <header class="header">
        <div class="header-logo">
            <a asp-controller="Dashboard" asp-action="index"
                   style="text-decoration: none; color: var(--blue-primary); font-weight: 700; font-size: 0.95rem;">
                <i class="ph ph-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </header>

    <main class="profile-page-container">
        <div class="auth-card profile-card">
            <h2 class="auth-title">My Profile</h2>

            <form>
                <div class="form-group">
                    <label class="form-label" for="fullname">Full Name</label>
                    <input disabled id="fullname" class="form-control" value="@Model.FullName.ToUpper()" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="username">Username</label>
                    <input disabled id="username" class="form-control" value="@Model.UserName" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="email">Email address</label>
                    <input disabled id="email" class="form-control" value="@Model.Email" required>
                </div>
            </form>

            <div class="danger-zone">
                <h3 class="danger-title">Danger Zone</h3>
                <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.25rem;">
                    Once you delete your account, there is no going back. All your projects and data will be permanently removed.
                </p>
                <a asp-action="DeleteAccount" class="btn btn-danger-outline" style="width: 100%; justify-content: center;">
                    <i class="ph ph-trash"></i> Delete Account
                </a>
            </div>
        </div>
    </main>

</body>

</html>
