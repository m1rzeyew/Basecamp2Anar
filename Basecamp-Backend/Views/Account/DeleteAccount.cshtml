@model DeleteAccountVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Account Deletion | Dashboard</title>
  
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>
<body>

    <!-- Header -->
    <header class="header">
        <div class="header-logo">
            <a asp-controller="dashboard" asp-action="index" style="text-decoration: none; color: var(--blue-primary); font-weight: 700; font-size: 0.95rem;">
                <i class="ph ph-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </header>

    <main class="auth-container">
        <div class="auth-card" id="deleteCard" style="max-width: 500px; border-top: 5px solid var(--red-primary);">
            <h2 class="auth-title" style="color: var(--red-primary); text-align: left; font-size: 1.5rem; margin-bottom: 0.75rem;">
                Delete your account? This action is permanent.
            </h2>
            <p style="margin-bottom: 2rem; color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                Once you delete your account, there is no going back. Please enter your account credentials to verify it's you.
            </p>

            <form method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label class="form-label" for="username">Username</label>
                    <input asp-for="UserName" id="username" class="form-control" placeholder="johndoe" required>
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input asp-for="Password" id="password" class="form-control" placeholder="••••••••" required>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div style="display: flex; gap: 1rem; margin-top: 2.5rem;">
                    <a asp-action="UserPage" class="btn btn-gray" style="flex: 1; justify-content: center; text-decoration: none;">Cancel</a>
                    <button asp-controller="Account" asp-action="DeleteAccount" type="submit" class="btn btn-danger" style="flex: 2; justify-content: center;">
                        Permanently Delete My Account
                    </button>
                </div>
            </form>
        </div>
    </main>

  
</body>
</html>

