@model DashboardVM
@{
    var isAdmin = User.IsInRole("Admin");
}

<main class="main-content">
    <div class="page-header">
        <h1 class="page-title">Projects</h1>
        @if (isAdmin)
        {
            <button class="btn btn-primary" onclick="openModal()">
                <i class="ph ph-plus-bold"></i> New Project
            </button>
        }
    </div>

    <div class="tabs">
        <a href="#" class="tab" data-filter="all">
            <i class="ph ph-squares-four"></i> All projects
        </a>
        <a href="#" class="tab" data-filter="created">
            <i class="ph ph-user"></i> Created by me
        </a>
        <a href="#" class="tab" data-filter="shared">
            <i class="ph ph-users"></i> Shared with me
        </a>
    </div>

    <div class="projects-grid">
        @foreach (var project in Model.AllProjects)
        {
            var isCreatedByMe = Model.CreatedByMe.Any(p => p.Id == project.Id);
            var filterClass = isCreatedByMe ? "created" : "shared";

            <article class="project-card @filterClass">
                <h3 class="project-title">
                    <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" style="text-decoration: none; color: inherit;">
                        @project.Name
                    </a>
                </h3>
                <div class="project-email">
                    <i class="ph ph-tag"></i> @(isCreatedByMe ? "Created by you" : "Shared with you")
                </div>
                <p class="project-desc">@project.Description</p>

                <div class="project-divider"></div>

                <div class="project-footer">
                    <div class="project-stats">
                        <div class="stat" title="Members">
                            <i class="ph ph-users"></i> @project.Members.Count
                        </div>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="project-actions">
                            <button type="button" class="btn-icon btn-edit" title="Edit Project" onclick="openEditModal('@project.Id', '@project.Name', '@project.Description')">
                                <i class="ph ph-pencil-simple"></i>
                            </button>
                            <button type="button" class="btn-icon btn-delete" title="Delete Project" onclick="directDeleteProject('@project.Id')" style="color: #dc3545;">
                                <i class="ph ph-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            </article>
        }
    </div>
</main>

@if (isAdmin)
{
    <div id="newProjectModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-primary);">Create New Project</h2>
                <button type="button" onclick="closeModal()" style="border: none; background: none; font-size: 1.25rem; cursor: pointer;">
                    <i class="ph ph-x"></i>
                </button>
            </div>

            <form asp-controller="Dashboard" asp-action="CreateProject" method="post">
                <div class="modal-body">
                    <div class="form-group" style="margin-bottom: 1rem;">
                        <label for="projectName" class="form-label">Project Name</label>
                        <input type="text" id="projectName" name="Name" class="form-control" placeholder="e.g. Website Redesign" required>
                    </div>
                    <div class="form-group" style="margin-bottom: 1.5rem;">
                        <label for="projectDesc" class="form-label">Description</label>
                        <textarea id="projectDesc" name="Description" class="form-control" rows="3" placeholder="Briefly describe the project..." required></textarea>
                    </div>
                </div>

                <div class="modal-footer" style="display: flex; gap: 1rem; justify-content: flex-end;">
                    <button type="button" class="btn btn-gray" onclick="closeModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Project</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editProjectModal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 600px;">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center;">
                <h2 style="font-size: 1.25rem; font-weight: 600;">Quick Edit</h2>
                <button type="button" onclick="closeEditModal()" style="border: none; background: none; font-size: 1.25rem; cursor: pointer;"><i class="ph ph-x"></i></button>
            </div>

            <form id="quickEditForm">
                <input type="hidden" id="editProjectId">
                <div class="modal-body" style="display: flex; gap: 15px; margin-top: 15px;">
                    <div style="flex: 1;">
                        <label class="form-label">Project Name</label>
                        <input type="text" id="editProjectName" class="form-control" required>
                    </div>
                    <div style="flex: 1;">
                        <label class="form-label">Description</label>
                        <textarea id="editProjectDesc" class="form-control" rows="1" style="resize: none;" required></textarea>
                    </div>
                </div>

                <div class="modal-footer" style="margin-top: 20px; text-align: right;">
                    <button type="button" class="btn btn-gray" onclick="closeEditModal()">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="saveProjectChanges()">Save</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <style>
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-content {
            background-color: #fff;
            border-radius: 8px;
            padding: 2rem;
            width: 100%;
            max-width: 500px;
            box-shadow: var(--shadow-md);
        }
    </style>

    @if (isAdmin)
    {
        <script>
            function openModal() {
                document.getElementById('newProjectModal').style.display = 'flex';
            }

            function closeModal() {
                document.getElementById('newProjectModal').style.display = 'none';
            }

            function openEditModal(id, name, desc) {
                document.getElementById('editProjectId').value = id;
                document.getElementById('editProjectName').value = name;
                document.getElementById('editProjectDesc').value = desc;
                document.getElementById('editProjectModal').style.display = 'flex';
            }

            function closeEditModal() {
                document.getElementById('editProjectModal').style.display = 'none';
            }

            function saveProjectChanges() {
                const data = {
                    Id: parseInt(document.getElementById('editProjectId').value),
                    Name: document.getElementById('editProjectName').value,
                    Description: document.getElementById('editProjectDesc').value
                };

                fetch('/Project/QuickEdit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                }).then(res => {
                    if (res.ok) {
                        location.reload();
                    } else {
                        alert("Could not update project.");
                    }
                });
            }

            function directDeleteProject(id) {
                if (confirm("Are you sure you want to delete this project?")) {
                    fetch(`/Project/HardDelete?id=${id}`, {
                        method: 'POST'
                    }).then(res => {
                        if (res.ok) {
                            location.reload();
                        } else {
                            alert("Could not delete project.");
                        }
                    });
                }
            }

            window.onclick = function(event) {
                const newModal = document.getElementById('newProjectModal');
                const editModal = document.getElementById('editProjectModal');
                if (event.target == newModal) closeModal();
                if (event.target == editModal) closeEditModal();
            }
        </script>
    }
}
